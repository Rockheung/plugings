{
  "description": "위험/비가역 Bash 명령에 15초 lazy 확인 다이얼로그를 거는 PreToolUse 게이트.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/timeout-deny.sh"
          }
        ]
      }
    ]
  }
}
